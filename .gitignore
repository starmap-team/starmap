# ==================== StarMap .gitignore ====================

# ---- 环境变量（含密钥，绝不提交）----
.env
.env.local
.env.*.local
!.env.example

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# 虚拟环境
venv/
env/
ENV/
.venv/

# 测试覆盖率
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Poetry
# poetry.lock 应该提交（锁定依赖，规范3）

# ---- Node / 前端 ----
node_modules/
frontend/dist/
frontend/dist-ssr/
*.local
.vite/

# 前端测试
frontend/coverage/

# 前端生成产物（从 starmap-contracts 生成，不进版本库）
frontend/src/api/schema.ts

# ---- IDE ----
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---- Docker 数据卷（本地）----
data/
volumes/

# ---- 日志 ----
*.log
logs/

# ---- 临时文件 ----
*.tmp
*.bak

# ---- 调试用临时文件 ----
_backend*.txt
_*.log

# ---- 临时脚本 ----
git_*.bat
git_*.ps1
cleanup.ps1

# ---- Codex / Agent 工具目录 ----
.codegraph/
.omc/
.omo/
graphify-out/
screenshots/

# ---- 一次性 patch 脚本 ----
_patch_*.py
_expand_*.py

# ---- Windows NUL 设备误生成 ----
nul

# ---- 前端临时生成 ----
frontend/gen_*.js
frontend/src/pages/*.vue.new
