# ==================== 星图(StarMap) 环境变量模板 ====================
# 用法：cp .env.example .env  然后填入真实值
# 注意：.env 文件不要提交到 git（已在 .gitignore 中）

# ---------- 数据库 ----------
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=starmap123456

POSTGRES_URI=postgresql+asyncpg://starmap:starmap123456@postgres:5432/starmap
POSTGRES_USER=starmap
POSTGRES_PASSWORD=starmap123456
POSTGRES_DB=starmap

REDIS_URI=redis://redis:6379/0

CHROMA_HOST=chroma
CHROMA_PORT=8000

# ---------- LLM ----------
# 讯飞星火 API（核心抽取，必填，全员共享配额）
XUNFEI_API_KEY=your_xunfei_api_key_here
XUNFEI_API_SECRET=your_xunfei_api_secret_here
XUNFEI_APP_ID=your_xunfei_app_id_here

# Qwen2.5-7B 本地模型（通过 docker-compose 中 Ollama 服务提供）
# 默认指向容器内 Ollama 服务；宿主机调试时改为 http://localhost:11434
QWEN_MODEL_PATH=http://ollama:11434

# ---------- 应用 ----------
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=INFO
SECRET_KEY=change_me_in_production

# ---------- 前端 ----------
VITE_API_BASE_URL=http://localhost:8000
